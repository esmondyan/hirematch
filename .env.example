# ============================================
# HireMatch 环境变量配置
# 复制此文件为 .env 并填入真实值: cp .env.example .env
# ============================================

# LLM Provider: deepseek | qwen | openai
LLM_PROVIDER=deepseek

# DeepSeek API (推荐，性价比最高)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DashScope API (备份选项)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI API (备份选项)
OPENAI_API_KEY=your_openai_api_key_here

# 匹配阈值 (0-100)，低于此分的候选人自动拒绝
MATCH_THRESHOLD=60

# 上传文件大小限制 (MB)
MAX_UPLOAD_SIZE_MB=5

# 数据库连接串 (SQLite 默认即可，无需修改)
DATABASE_URL=sqlite:///./data/hirematch.db

# Session 密钥 (生产环境请改为随机字符串)
SESSION_SECRET_KEY=hirematch-dev-secret-change-in-production
